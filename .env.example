# ============================================================
# ChatBulário — variáveis de ambiente
# Copie para .env e preencha com suas chaves reais.
# ============================================================

# ------------------------------------------------------------
# Provider LLM para extração de metadados (process/meta_llm.py)
# Valores: openai | groq
# ------------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI — gpt-4o-mini (~$1,07 para o dataset completo, ~20 min)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Groq — llama-3.1-8b-instant (free tier: 30 RPM / 6K TPM / 14.4K RPD)
# Gargalo: TPM → ~7 req/min efetivo → ~12h para o dataset completo
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# Publicação do dataset no HuggingFace (export.py --upload)
# ------------------------------------------------------------
# Token com permissão de escrita: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...
# Repositório de destino (dataset)
HF_REPO_ID=walmeidadf/ChatBulario
